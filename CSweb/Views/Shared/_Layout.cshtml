@* #C, codigo al servidor *@
@* Al picarle a algun boton de la toolbar, Actualiza en que pagina se encuentra el usuario mediante una comparacion.  *@
@* ? evita que se crashee, si existe action lo convierte a texto. si no, devuelve null.  *@

@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    string ActiveClass(string action)
    {if (currentAction == action)
        { return "active";
        }
    else
        { return "";
        }
    }
}

<!DOCTYPE html>
<head>
    <meta charset="utf-8" />
    @* adapta las dimensiones y escala de la web dependiendo del disp en el q estes *@
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @* ViewData (contenedor) despliega (arriba en la pestaña) en que pagina estas actualmente  *@
    <title>@ViewData["Title"] - Cobalt Legends</title>
    @* librerias de estilo  *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">  @* importa libreria de iconos de bootstrap*@
    @* asp-.. crea un hash para comprar con el hash (anterior) en la cache y asegurarse q los cambios se hayan actualizado   *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>


<body >
    @* toolbar *@
    @* position.. al dar scroll no se mueve el toolbar *@
    @* w-100.. pone el ancho de la pagina al 100% *@
    <header class="position-fixed w-100 tb-container">
    <div class="container-fluid px-4 py-3">
        <div class="row align-items-center">

            @* columna izquierda vacía para balancear *@
            <div class="col-2"></div>

            @* columna central: toolbar *@
            <div class="col-8 d-flex justify-content-center">
                @* navbar estabelce el contenedor como barra de nav *@
                @* navbar-ex.. hace q los iconos no se distorsionen al hacer la pag chiquita *@
                <nav class="navbar navbar-expand bg-white bg-opacity-75 border rounded-pill shadow px-3 py-2 toolbar-blur">
                    <div class="navbar-nav flex-row gap-1">

                        <a class="nav-link toolbar-icon rounded-pill px-3 @ActiveClass("Index")"
                           asp-controller="Home"
                           asp-action="Index"
                           title="Inicio">
                            <i class="bi bi-house"></i>
                        </a>

                        <a class="nav-link toolbar-icon rounded-pill px-3 @ActiveClass("Explorar")"
                           asp-controller="Home"
                           asp-action="Explorar"
                           title="Explorar">
                            <i class="bi bi-compass"></i>
                        </a>

                        <a class="nav-link toolbar-icon rounded-pill px-3 @ActiveClass("Crear")"
                           asp-controller="Home"
                           asp-action="Crear"
                           title="Crear">
                            <i class="bi bi-plus-square"></i>
                        </a>

                        <a class="nav-link toolbar-icon rounded-pill px-3 @ActiveClass("Juego")"
                           asp-controller="Home"
                           asp-action="Juego"
                           title="Juego">
                            <i class="bi bi-controller"></i>
                        </a>

                        <a class="nav-link toolbar-icon rounded-pill px-3 @ActiveClass("Ranking")"
                           asp-controller="Home"
                           asp-action="Ranking"
                           title="Ranking">
                            <i class="bi bi-trophy"></i>
                        </a>

                        <a class="nav-link toolbar-icon rounded-pill px-3 @ActiveClass("Perfil")"
                           asp-controller="Home"
                           asp-action="Perfil"
                           title="Perfil">
                            <i class="bi bi-person"></i>
                        </a>

                    </div>
                </nav>
            </div>

            @* columna derecha: perfil *@
            <div class="col-2 d-none d-md-flex justify-content-end">
                <div class="dropdown">
                    <button class="btn bg-white bg-opacity-75 border rounded-pill shadow d-flex align-items-center gap-2 px-3 py-2 toolbar-blur"
                            type="button"
                            data-bs-toggle="dropdown"
                            aria-expanded="false">

                        <span class="rounded-circle d-inline-flex align-items-center justify-content-center text-white fw-semibold profile-circle">
                            SC
                        </span>

                        <span class="fw-semibold small">Jimmy</span>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 mt-2 p-2">
                        <li class="px-3 py-2">
                            <p class="mb-0 fw-semibold small">Jimmy</p>
                            <p class="mb-0 text-muted small">Sesión: Invitado</p>
                        </li>

                        <li>
                            <a class="dropdown-item small rounded-3"
                               asp-controller="Home"
                               asp-action="Ajustes">
                                <i class="bi bi-gear"></i> : Ajustes
                            </a>
                        </li>

                        <li><hr class="dropdown-divider" /></li>

                        <li>
                            <a class="dropdown-item small rounded-3 text-danger"
                               asp-controller="Home"
                               asp-action="Login">
                                <i class="bi bi-box-arrow-right"></i> : Cerrar Sesión
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

        </div>
    </div>
</header>

    <!-- Contenido principal -->
    <main role="main" class="main-content">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>