@{
    ViewData["Title"] = "Juego";
    Layout = "_Layout";
}

<div class="game-page">
    <div class="container py-5">

        <div class="game-card shadow-lg">

            <div class="game-hero">
                <img src="~/Imagenes/juego/cobalt-legends-preview.png"
                     alt="Cobalt Legends"
                     class="game-hero-img" />

                <div class="game-overlay"></div>

                <div class="game-content">
                    <h1>Cobalt Legends</h1>

                    <p>
                        Embárcate en una aventura épica y gana gemas para desbloquear personalizaciones exclusivas
                    </p>

                    <a href="#" class="btn game-start-btn">
                        <i class="bi bi-play"></i>
                        Iniciar Juego
                    </a>
                </div>
            </div>

            <div class="game-stats">
                <h2>2,450</h2>
                <p>Gemas Ganadas</p>
            </div>

        </div>

    </div>
</div>