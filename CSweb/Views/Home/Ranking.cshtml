@model CSweb.Models.RankingViewModel


@{
    ViewData["Title"] = "Home Page";
}

<div class="container-fluid">
        <div class="row">
            <div class="col-9 mb-5">

            @using (Html.BeginForm("Ranking", "Home", FormMethod.Get))
    {
                <div class="search-container position-relative d-flex align-items-center">
                   
                        <svg class="search-icon" ...></svg>

                        <input class="form-control search-input ps-5"
                            type="search"
                            name="query"
                            placeholder="Buscar usuarios...">

                        <button class=" btn btn-search ms-2" type="submit">
                            Buscar
                        </button>
                    
                </div>
                }
            </div>
        </div>
    </div>


<div class="container">


    <div class="row">

        <!--contenedor donde va la lista de usuarios-->
        <div class ="container col-9">

            @if(Model?.Usuarios != null)
            {
                @for(int i = 0; i < Model.Usuarios.Count && i < 100; i++)
                {
                    <div class="card p-2 mb-2 border-light rounded-4" style="background: #9ec8ef;">
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="d-flex align-items-center gap-3 w-100">
                                <img src="usuario.jpg" class="rounded-circle" width="50">
                                <div>
                                    <h6 class="mb-0 ">@Model.Usuarios[i].userName</h6>
                                    <small class="text-muted">@Model.Usuarios[i].Puntos puntos</small>
                                </div>
                                <span class="text-muted ms-auto fs-6">TOP @Model.Usuarios[i].Posicion</span>
                            </div>
                        </div>
                    </div>
                }
            }
        
            <!--fila de usuario-->
            @if(Model?.UsuarioActual != null)
            {
                <div class="card p-2 mb-2 border-light rounded-4" style="background: #d4a574;">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-3 w-100">
                            <img src="usuario.jpg" class="rounded-circle" width="50">
                            <div>
                                <h6 class="mb-0">@Model.UsuarioActual.userName (TÚ)</h6>
                                <small class="text-muted">@Model.UsuarioActual.Puntos puntos</small>
                            </div>
                            <span class="text-muted ms-auto fs-6">TOP @Model.UsuarioActual.Posicion</span>
                        </div>
                    </div>
                </div>
            }

            
            
        </div>


        <!--contenedores de la derecha (posicion usuario, guia de puntos)-->
        <div class="col-3 d-flex flex-column">

            <!--contenedor con posicion del usuario-->
            @if(Model?.UsuarioActual != null)
            {
                <div class="card p-4 mb-4 border-light rounded-4 d-flex flex-column align-items-start " style= "background: #13518b;" >
                    <h4 class="text-white  mb-4">Tu posición</h4>

                    <!--circulo con pos-->
                    <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center bg-opacity-10 mb-3" style="width: 60px; height: 60px; background: #1663ab24;">
                        <span class="text-white fs-3">@Model.UsuarioActual.Posicion</span>
                    </div>
                    <!--contenedor con puntos -->
                    <div class=" d-flex align-items-center gap-2  mb-3">
                     <!--imagen puntos-->
                        <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" fill="white" class="bi bi-award-fill" viewBox="0 0 16 16">
                            <path d="m8 0 1.669.864 1.858.282.842 1.68 1.337 1.32L13.4 6l.306 1.854-1.337 1.32-.842 1.68-1.858.282L8 12l-1.669-.864-1.858-.282-.842-1.68-1.337-1.32L2.6 6l-.306-1.854 1.337-1.32.842-1.68L6.331.864z"/>
                            <path d="M4 11.794V16l4-1 4 1v-4.206l-2.018.306L8 13.126 6.018 12.1z"/>
                        </svg>
                        <h5 class="text-white mb-0">@Model.UsuarioActual.Puntos Puntos</h5>
                    </div>
                </div>
            }

            <!--contenedor con guia de puntos -->

            <div class ="card  p-4 mb-4 border-light rounded-4  shadow d-flex flex-column align-items-start" style= "background: #13518b;">
                <!--titulo-->
                <div class=" d-flex align-items-center gap-2  mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="white" class="bi bi-stars" viewBox="0 0 16 16">
                        <path d="M7.657 6.247c.11-.33.576-.33.686 0l.645 1.937a2.89 2.89 0 0 0 1.829 1.828l1.936.645c.33.11.33.576 0 .686l-1.937.645a2.89 2.89 0 0 0-1.828 1.829l-.645 1.936a.361.361 0 0 1-.686 0l-.645-1.937a2.89 2.89 0 0 0-1.828-1.828l-1.937-.645a.361.361 0 0 1 0-.686l1.937-.645a2.89 2.89 0 0 0 1.828-1.828zM3.794 1.148a.217.217 0 0 1 .412 0l.387 1.162c.173.518.579.924 1.097 1.097l1.162.387a.217.217 0 0 1 0 .412l-1.162.387A1.73 1.73 0 0 0 4.593 5.69l-.387 1.162a.217.217 0 0 1-.412 0L3.407 5.69A1.73 1.73 0 0 0 2.31 4.593l-1.162-.387a.217.217 0 0 1 0-.412l1.162-.387A1.73 1.73 0 0 0 3.407 2.31zM10.863.099a.145.145 0 0 1 .274 0l.258.774c.115.346.386.617.732.732l.774.258a.145.145 0 0 1 0 .274l-.774.258a1.16 1.16 0 0 0-.732.732l-.258.774a.145.145 0 0 1-.274 0l-.258-.774a1.16 1.16 0 0 0-.732-.732L9.1 2.137a.145.145 0 0 1 0-.274l.774-.258c.346-.115.617-.386.732-.732z"/>
                    </svg>
                    <h5 class="text-white mb-0">¿Cómo se ganan puntos?</h5>
                </div>
                
                <!--Contenedor de elementos -->
                <div class="d-flex flex-column">

                    <!--publicar prompts -->
                    <div class=" d-flex align-items-center   mb-3 gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="white" class="bi bi-lightbulb mr-2" viewBox="0 0 16 16">
                                <path d="M2 6a6 6 0 1 1 10.174 4.31c-.203.196-.359.4-.453.619l-.762 1.769A.5.5 0 0 1 10.5 13a.5.5 0 0 1 0 1 .5.5 0 0 1 0 1l-.224.447a1 1 0 0 1-.894.553H6.618a1 1 0 0 1-.894-.553L5.5 15a.5.5 0 0 1 0-1 .5.5 0 0 1 0-1 .5.5 0 0 1-.46-.302l-.761-1.77a2 2 0 0 0-.453-.618A5.98 5.98 0 0 1 2 6m6-5a5 5 0 0 0-3.479 8.592c.263.254.514.564.676.941L5.83 12h4.342l.632-1.467c.162-.377.413-.687.676-.941A5 5 0 0 0 8 1"/>
                            </svg>
                            <div >
                                <p class="text-white mb-0 small">Publicar un prompt</p>
                                <small class=" text-white mt-0">+10 puntos</small>
                            </div>       
                    </div>

                      <!--Recibir un comentario -->
                    <div class=" d-flex align-items-center   mb-3 gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="white" class="bi bi-chat" viewBox="0 0 16 16">
                                <path d="M2.678 11.894a1 1 0 0 1 .287.801 11 11 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8 8 0 0 0 8 14c3.996 0 7-2.807 7-6s-3.004-6-7-6-7 2.808-7 6c0 1.468.617 2.83 1.678 3.894m-.493 3.905a22 22 0 0 1-.713.129c-.2.032-.352-.176-.273-.362a10 10 0 0 0 .244-.637l.003-.01c.248-.72.45-1.548.524-2.319C.743 11.37 0 9.76 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7-3.582 7-8 7a9 9 0 0 1-2.347-.306c-.52.263-1.639.742-3.468 1.105"/>
                            </svg>
                            <div>
                                <p class="text-white mb-0 small">Recibir un comentario</p>
                                <small class=" text-white mt-0">+10 puntos</small>
                            </div>       
                    </div>

                      <!--Recibir un like -->
                    <div class=" d-flex align-items-center   mb-3 gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" fill="white" class="bi bi-heart-fill" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M8 1.314C12.438-3.248 23.534 4.735 8 15-7.534 4.736 3.562-3.248 8 1.314"/>
                            </svg>
                            <div >
                                <p class="text-white mb-0 small">Recibir un like</p>
                                <small class=" text-white mt-0">+10 puntos</small>
                            </div>       
                    </div>

                      <!--Ser guardado -->
                      
                    <div class=" d-flex align-items-center   mb-3 gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="21" height="21" fill="white" class="bi bi-bookmark-fill" viewBox="0 0 16 16">
                                <path d="M2 2v13.5a.5.5 0 0 0 .74.439L8 13.069l5.26 2.87A.5.5 0 0 0 14 15.5V2a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2"/>
                            </svg>
                            <div >
                                <p class="text-white mb-0 small">Ser guardado</p>
                                <small class=" text-white mt-0">+10 puntos</small>
                            </div>       
                    </div>

            </div>
        </div>
    </div>
</div>