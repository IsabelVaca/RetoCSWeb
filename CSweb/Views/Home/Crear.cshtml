@model CSweb.Models.PromptViewModelCrear



<!-- contenedor general de la página (py es padding vertical 4)(btsp container para que no tome todo el ancho de la pagina) -->
<div class="create-page py-4">
    <div class="container">

        <!--grid principal: divide la pantalla en columna izquierda y columna derecha(total 3fr)(2fractions a izq, 1fr a derecha) -->
        <div class="main-grid">

            <!--columna izquierda-->
            <main>

                <!--card principal del formulario-->
                <section class="card-form">

                    <!--título de card del formulario-->
                    <h2 class="card-title-custom">
                        <i class="bi bi-stars"></i>
                        Crea tu Prompt
                    </h2>

                    <!-- formulario que manda los datos al método Create del HomeController -->
                    <form method="post" asp-action="Crear">

                    <!-- campo:Título -->
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Título</label>

                            <input asp-for="Title"
                                   class="form-control form-control-custom"
                                   placeholder="Dale un título a tu creación..." />
                        </div>
                  
                    <!-- campo:Categoría -->
                        <div class="mb-3">
                            <label asp-for="IdCategoria" class="form-label">Categoría</label>

                            <select asp-for="IdCategoria" class="form-control form-control-custom">
                                <option value="">Selecciona una categoría...</option>

                                @foreach (var categoria in Model.Categorias)
                                {
                                    <option value="@categoria.IdCategoria">@categoria.Nombre</option>
                                }
                            </select>
                        </div>

                    <!-- campo:Descripción -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Descripción</label>

                            <input asp-for="Description"
                                   class="form-control form-control-custom"
                                   placeholder="Describe brevemente de qué trata tu prompt..." />
                        </div>

                    <!-- campo:Prompt -->
                        <div class="mb-4">
                            <label asp-for="Prompt" class="form-label">Prompt</label>

                            <textarea asp-for="Prompt"
                                      rows="10"
                                      class="form-control form-control-custom"
                                      placeholder="Escribe aquí el prompt completo que quieres publicar..."></textarea>
                        </div>

                        <!-- botones del formulario -->
                        <div class="button-row">

                            <!-- botón Publicar (empieza desactivado y se activa con JavaScript cuando los campos tienen texto) -->
                            <button id="generateButton" type="submit" class="btn btn-generate" disabled>
                                Publicar
                            </button>

                            <!-- botón para limpiar formulario -->
                            <button id="clearButton" type="button" class="btn btn-clear">
                                Limpiar
                            </button>

                        </div>
                    </form>
                </section>

                <!-- card prompts de ejemplo -->
                <section class="card-custom">

                    <h3 class="card-title-custom">
                        <i class="bi bi-rainbow"></i>
                        Prompts de Ejemplo
                    </h3>

                    <!-- lista de ejemplos-->
                    <ul class="example-list">
                        <li>
                            Un espacio de trabajo minimalista y sereno con iluminación natural, escritorio de madera y plantas verdes.
                        </li>

                        <li>
                            Arte geométrico abstracto con degradados vibrantes de púrpura y azul, moderno y dinámico.
                        </li>

                        <li>
                            Rincón acogedor de lectura en una biblioteca con iluminación ambiental cálida durante el atardecer.
                        </li>
                    </ul>

        </section>
</main>

<!-- columna derecha-->
<aside>
<!-- card guia -->
<section class="card-custom">
    <h2 class="card-title-custom">
        <i class="bi bi-lightning"></i>
        Guía de Escritura de Prompts
    </h2>

    <p class="card-text-custom mb-0">
        Sigue estos consejos para crear prompts mas efectivos.
    </p>
</section>

@{
    string[] clasesCards = { "card-orange", "card-blue", "card-green", "card-yellow" };
    string[] iconosCards = { "bi-lightbulb", "bi-check-circle", "bi-book", "bi-exclamation-circle" };
    int contadorTip = 0;
}

@foreach (var tip in Model.Tips)
{
    var clase = clasesCards[contadorTip % clasesCards.Length];
    var icono = iconosCards[contadorTip % iconosCards.Length];

    <section class="card-custom @clase">
        <h3 class="card-title-custom">
            <i class="bi @icono"></i>
            @(contadorTip + 1). @tip.Titulo
        </h3>

        <p class="card-text-custom">
            @tip.Descripcion
        </p>

        <p class="card-text-custom mb-0">
            Ejemplo: "@tip.Ejemplo"
        </p>
    </section>

    contadorTip++;
}
                <!-- card consejos rapidos -->
                <section class="card-custom">
                    <h3 class="card-title-custom">
                        <i class="bi bi-magic"></i>
                        Consejos Rápidos
                    </h3>

                    <ul class="example-list">
                    @foreach (var consejo in Model.ConsejosRapidos)
                    {
                        <li>@consejo.Texto</li>
                    }
                    </ul>
                </section>

            </aside>

        </div>
    </div>
</div>

<!-- confirmación -->

<!-- solo aparece cuando el Controller manda un mensaje en ViewData["Mensaje"](modal es clase de btsp ) -->
@if (ViewData["Mensaje"] != null)
{
    <div class="modal fade show" tabindex="-1" style="display:block; background-color: rgba(172, 221, 237, 0.898);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-3 shadow">

                <div class="modal-header">
                   <i class="bi bi-check2-circle"></i>
                    <h5 class="modal-title">   Prompt publicado</h5>
                </div>

                <div class="modal-body">
                    <p class="mb-0">@ViewData["Mensaje"]</p>
                </div>

                <div class="modal-footer">
                    <a asp-action="Crear" class="btn btn-primary">
                        Ok
                    </a>
                </div>

            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/crear.js" asp-append-version="true"></script>
    }

