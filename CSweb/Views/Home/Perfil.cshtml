@* Perfil: cabecera, pestañas (?tab=), editar, actividad o tarjetas. Datos en @Model y ViewBag (HomeController.PrepararViewBagPerfil). *@
@model CSweb.Models.PerfilViewModel
@{
    ViewData["Title"] = "Perfil";
    var editar = (PerfilEditarViewModel)ViewBag.PerfilEditar!;
    var prompts = (List<PromptViewModel>)ViewBag.Prompts!;
    var tab = (string)ViewBag.Tab!;
    var enEditar = (bool)ViewBag.EnEditar;
    var enActividad = (bool)ViewBag.EnActividad;
    var enGuardados = (bool)ViewBag.EnGuardados;
    var enLikeados = (bool)ViewBag.EnLikeados;
}
<div class="py-5">
  <div class="container perfil-page">
    <div class="mb-5">
      <div class="row align-items-start">
        <div class="col-md-3 d-flex justify-content-center">
          <img src="@ViewBag.UrlFotoCabecera" alt="Foto de perfil" class="img-fluid rounded-4 perfil-foto-principal"
               style="width: 250px; height: 250px; object-fit: cover;">
        </div>
        <div class="col-md-9 ps-4">
          <h1 class="perfil-nombre fw-bold mb-2">@Model.Nombre</h1>
          <p class="perfil-handle text-muted mb-3">@@@Model.UserName</p>
          <p class="perfil-bio text-dark mb-2">@Model.Bio</p>
          <p class="perfil-stats mb-2"><span class="fw-bold">@Model.NumeroPublicaciones</span> <span class="text-muted">publicados</span></p>
          @if (TempData["PerfilError"] is string err)
          {
            <div class="alert alert-danger py-2 px-3 small mb-2">@err</div>
          }
          @if (TempData["PerfilMensaje"] is string ok)
          {
            <div class="alert alert-success py-2 px-3 small mb-2">@ok</div>
          }
          @if (!enEditar)
          {
            <a class="btn btn-sm rounded-pill px-3 perfil-btn-editar" asp-action="Perfil" asp-route-tab="editar">
              <i class="bi bi-pencil-square me-1"></i> Editar
            </a>
          }
        </div>
      </div>

      @if (!enEditar)
      {
        <div class="row mt-4 mb-3">
          <div class="col-12 d-flex justify-content-center justify-content-md-start">
            <nav class="navbar navbar-expand bg-white bg-opacity-75 border rounded-pill shadow px-2 py-2 toolbar-blur perfil-pubs-nav">
              <div class="navbar-nav flex-row flex-wrap gap-1">
                @foreach (var t in (IEnumerable<(string Id, string Icon, string Label)>)ViewBag.TabsNav!)
                {
                  <a class="nav-link toolbar-icon rounded-pill px-2 px-sm-3 d-inline-flex align-items-center gap-1 @(tab == t.Id ? "active" : "")"
                     asp-action="Perfil" asp-route-tab="@t.Id"><i class="bi @t.Icon"></i><span class="perfil-tab-text">@t.Label</span></a>
                }
              </div>
            </nav>
          </div>
        </div>
      }

      <div class="row@(enEditar ? " mt-4" : "")">
        <div class="col-12 perfil-tab-panel rounded-3 border bg-white bg-opacity-75 p-4">

          @if (enEditar)
          {
            <h2 class="h5 fw-semibold mb-3">Editar</h2>
            <form asp-action="EditarPerfil" method="post" enctype="multipart/form-data" class="perfil-editar-form">
              <input type="hidden" name="RutaFotoPerfil" value="@(editar.RutaFotoPerfil ?? "")" />
              <div asp-validation-summary="All" class="text-danger small mb-3"></div>
              <div id="perfil-editar-errores-cliente" class="text-danger small mb-3 d-none"></div>
              <div class="row g-3">
                <div class="col-md-4 text-center">
                  <img src="@ViewBag.UrlFotoEditar" alt="Foto" class="img-fluid rounded-4 perfil-foto-preview mb-2" id="perfil-foto-preview" />
                  <label class="form-label small fw-semibold" for="perfil-editar-foto">Foto</label>
                  <input type="file" id="perfil-editar-foto" name="FotoPerfil" class="form-control form-control-sm rounded-3" />
                  <p id="perfil-formatos-foto" class="text-muted extra-small mb-0"></p>
                </div>
                <div class="col-md-8">
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label small fw-semibold" for="perfil-editar-nombre">Nombre</label>
                      <input type="text" id="perfil-editar-nombre" name="Nombre" class="form-control rounded-3" value="@editar.Nombre" required />
                    </div>
                    <div class="col-md-6">
                      <label class="form-label small fw-semibold" for="perfil-editar-user">Usuario</label>
                      <div class="input-group">
                        <span class="input-group-text rounded-start-3">@@</span>
                        <input type="text" id="perfil-editar-user" name="UserName" class="form-control rounded-end-3" value="@editar.UserName" required />
                      </div>
                    </div>
                    <div class="col-12">
                      <label class="form-label small fw-semibold" for="perfil-editar-bio">Biografía</label>
                      <textarea id="perfil-editar-bio" name="Bio" class="form-control rounded-3" rows="4">@editar.Bio</textarea>
                      <p class="text-muted extra-small text-end mb-0"><span id="contador-chars">0</span>/500</p>
                    </div>
                  </div>
                </div>
              </div>
              <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn perfil-btn-guardar rounded-pill px-4">Guardar cambios</button>
                <a class="btn btn-outline-secondary rounded-pill px-4" asp-action="Perfil" asp-route-tab="publicados">Cancelar</a>
              </div>
            </form>
          }
          else if (enActividad)
          {
            <p class="fw-semibold mb-3">Actividad en tus prompts</p>
            @if (Model.Actividad.Count == 0)
            {
              <p class="text-muted mb-0">Sin actividad reciente.</p>
            }
            else
            {
              <ul class="list-unstyled mb-0 perfil-actividad-list">
                @foreach (var ev in Model.Actividad)
                {
                  var tipo = ev.Tipo.ToLowerInvariant();
                  var icono = tipo == "guardado" ? "bi-bookmark-fill" : tipo == "like" ? "bi-heart-fill" : "bi-chat-dots-fill";
                  var verbo = tipo == "guardado" ? " guardó " : tipo == "like" ? " dio me gusta a " : " comentó en ";
                  <li class="perfil-actividad-item d-flex gap-3 py-3 border-bottom border-light">
                    <div class="perfil-actividad-icon rounded-circle d-flex align-items-center justify-content-center flex-shrink-0">
                      <i class="bi @icono text-white small"></i>
                    </div>
                    <div class="flex-grow-1">
                      <p class="mb-1 small">
                        <span class="fw-semibold">@ev.ActorNombre</span>
                        <span class="text-muted">@@@ev.ActorUserName</span>@verbo<span class="fw-semibold">«@ev.TituloPrompt»</span>
                      </p>
                      @if (tipo == "comentario" && !string.IsNullOrWhiteSpace(ev.ExtractoComentario))
                      {
                        <p class="mb-1 small text-muted fst-italic border-start border-3 ps-2 perfil-actividad-cita">@ev.ExtractoComentario</p>
                      }
                      <p class="mb-0 text-muted extra-small">@ev.Momento</p>
                    </div>
                  </li>
                }
              </ul>
            }
          }
          else if (prompts.Count == 0)
          {
            <p class="text-muted mb-0">No hay prompts en esta sección.</p>
          }
          else
          {
            <div class="row g-3">
              @foreach (var p in prompts)
              {
                <div class="col-12 col-md-6">
                  <div class="card border-0 shadow-sm rounded-4 prompt-card h-100">
                    <div class="card-body p-3">
                      <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="avatar-circle text-white fw-semibold" style="background-color:@p.CircleColor">@p.InitialsProfile</div>
                        <div>
                          <p class="mb-0 fw-semibold small">@p.AuthorName</p>
                          <p class="mb-0 text-muted extra-small">@@@p.Username</p>
                        </div>
                      </div>
                      <h3 class="h6 fw-semibold mb-2">@p.Title</h3>
                      <span class="badge categoria-badge rounded-pill px-2 py-1 small">@p.Category</span>
                      <div class="prompt-content rounded-3 p-2 my-2">
                        <p class="mb-0 text-muted small">@p.Prompt</p>
                      </div>
                      <div class="d-flex justify-content-between pt-3 border-top flex-wrap gap-2 text-muted">
                        <div class="d-flex gap-3">
                          <button type="button" class="stat-icon-btn like-btn@(enLikeados ? " liked" : "")" aria-pressed="@(enLikeados ? "true" : "false")">
                            <i class="bi @(enLikeados ? "bi-heart-fill" : "bi-heart")"></i><span class="like-count">@p.Likes</span>
                          </button>
                          <button type="button" class="stat-icon-btn js-perfil-toggle-comments" data-target="comments-@p.Id" aria-expanded="false">
                            <i class="bi bi-chat"></i><span class="comment-count">@p.Comments</span>
                          </button>
                          <button type="button" class="stat-icon-btn save-btn@(enGuardados ? " saved" : "")" aria-pressed="@(enGuardados ? "true" : "false")">
                            <i class="bi @(enGuardados ? "bi-bookmark-fill" : "bi-bookmark")"></i><span class="save-count">@p.Saves</span>
                          </button>
                        </div>
                        <span class="extra-small">@p.CreatedAt</span>
                      </div>
                      <div class="comment-section mt-4 pt-4 border-top" id="comments-@p.Id">
                        <form asp-action="PublicarComentarioPerfil" method="post" class="d-flex gap-2 flex-wrap">
                          <input type="hidden" name="promptId" value="@p.Id" />
                          <input type="hidden" name="returnTab" value="@tab" />
                          <input type="text" name="comentario" class="form-control rounded-4 comment-input flex-grow-1" placeholder="Añadir un comentario..." maxlength="500" />
                          <button type="submit" class="btn publicar-btn rounded-4 px-3">Publicar</button>
                        </form>
                      </div>
                    </div>
                  </div>
                </div>
              }
            </div>
          }

        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script src="~/js/perfil.js" asp-append-version="true"></script>
}
