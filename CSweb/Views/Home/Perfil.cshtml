@* Perfil: cabecera, pestañas (?tab=), editar, actividad o tarjetas. Datos en @Model y ViewBag (HomeController.PrepararViewBagPerfil). *@
@model CSweb.Models.PerfilViewModel
@{
    ViewData["Title"] = "Perfil";
    var editar = (PerfilEditarViewModel)ViewBag.PerfilEditar!;
    var prompts = (List<PromptViewModel>)ViewBag.Prompts!;
    var tab = (string)ViewBag.Tab!;
    var enEditar = (bool)ViewBag.EnEditar;
    var enActividad = (bool)ViewBag.EnActividad;
}
<div class="py-5">
  <div class="container perfil-page">
    <div class="mb-5">
      <div class="row align-items-start">
        <div class="col-md-3 d-flex justify-content-center">
          <img src="@ViewBag.UrlFotoCabecera" alt="Foto de perfil" class="img-fluid rounded-4 perfil-foto-principal"
               style="width: 250px; height: 250px; object-fit: cover;">
        </div>
        <div class="col-md-9 ps-md-4 perfil-info-col">
          @* Fila nombre + Editar: grid Bootstrap para alinear el botón arriba a la derecha *@
          <div class="row align-items-center g-2 perfil-header-top mb-2">
            <div class="col">
              <h1 class="perfil-nombre fw-bold mb-0">@Model.Nombre</h1>
            </div>
            @if (!enEditar)
            {
              <div class="col-auto">
                <a class="btn rounded-pill px-4 perfil-btn-editar" asp-action="Perfil" asp-route-tab="editar">
                  <i class="bi bi-pencil-square me-1"></i> Editar
                </a>
              </div>
            }
          </div>
          <p class="perfil-handle text-muted mb-3">@@@Model.UserName</p>
          <p class="perfil-bio text-dark mb-3">@Model.Bio</p>
          <p class="perfil-stats mb-0"><span class="fw-bold">@Model.NumeroPublicaciones</span> <span class="text-muted">publicados</span></p>
          @if (TempData["PerfilError"] is string err)
          {
            <div class="alert alert-danger py-2 px-3 small mb-2 mt-3">@err</div>
          }
          @if (TempData["PerfilMensaje"] is string ok)
          {
            <div class="alert alert-success py-2 px-3 small mb-2 mt-3">@ok</div>
          }
        </div>
      </div>

      @if (!enEditar)
      {
        <div class="row mt-4 mb-3">
          <div class="col-12 d-flex justify-content-center justify-content-md-start">
            <nav class="navbar navbar-expand bg-white bg-opacity-75 border rounded-pill shadow px-2 py-2 toolbar-blur perfil-pubs-nav">
              <div class="navbar-nav flex-row flex-wrap gap-1">
                @foreach (var t in (IEnumerable<(string Id, string Icon, string Label)>)ViewBag.TabsNav!)
                {
                  <a class="nav-link toolbar-icon rounded-pill px-2 px-sm-3 d-inline-flex align-items-center gap-1 @(tab == t.Id ? "active" : "")"
                     asp-action="Perfil" asp-route-tab="@t.Id"><i class="bi @t.Icon"></i><span class="perfil-tab-text">@t.Label</span></a>
                }
              </div>
            </nav>
          </div>
        </div>
      }

      <div class="row@(enEditar ? " mt-4" : "")">
        <div class="col-12 perfil-tab-panel rounded-3 border bg-white bg-opacity-75 p-4@(enActividad ? " perfil-tab-panel--actividad" : "")">

          @if (enEditar)
          {
            <h2 class="h5 fw-semibold mb-3">Editar</h2>
            <form asp-action="EditarPerfil" method="post" enctype="multipart/form-data" class="perfil-editar-form">
              <input type="hidden" name="RutaFotoPerfil" value="@(editar.RutaFotoPerfil ?? "")" />
              <div asp-validation-summary="All" class="text-danger small mb-3"></div>
              <div id="perfil-editar-errores-cliente" class="text-danger small mb-3 d-none"></div>
              <div class="row g-3">
                <div class="col-md-4 text-center">
                  <img src="@ViewBag.UrlFotoEditar" alt="Foto" class="img-fluid rounded-4 perfil-foto-preview mb-2" id="perfil-foto-preview" />
                  <label class="form-label small fw-semibold" for="perfil-editar-foto">Foto</label>
                  <input type="file" id="perfil-editar-foto" name="FotoPerfil" class="form-control form-control-sm rounded-3" />
                  <p id="perfil-formatos-foto" class="text-muted extra-small mb-0"></p>
                </div>
                <div class="col-md-8">
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label small fw-semibold" for="perfil-editar-nombre">Nombre</label>
                      <input type="text" id="perfil-editar-nombre" name="Nombre" class="form-control rounded-3" value="@editar.Nombre" required />
                    </div>
                    <div class="col-md-6">
                      <label class="form-label small fw-semibold" for="perfil-editar-user">Usuario</label>
                      <div class="input-group">
                        <span class="input-group-text rounded-start-3">@@</span>
                        <input type="text" id="perfil-editar-user" name="UserName" class="form-control rounded-end-3" value="@editar.UserName" required />
                      </div>
                    </div>
                    <div class="col-12">
                      <label class="form-label small fw-semibold" for="perfil-editar-bio">Biografía</label>
                      <textarea id="perfil-editar-bio" name="Bio" class="form-control rounded-3" rows="4">@editar.Bio</textarea>
                      <p class="text-muted extra-small text-end mb-0"><span id="contador-chars">0</span>/500</p>
                    </div>
                  </div>
                </div>
              </div>
              <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn perfil-btn-guardar rounded-pill px-4">Guardar cambios</button>
                <a class="btn btn-outline-secondary rounded-pill px-4" asp-action="Perfil" asp-route-tab="publicados">Cancelar</a>
              </div>
            </form>
          }
          else if (enActividad)
          {
            <p class="fw-semibold mb-3 perfil-seccion-titulo">Actividad en tus prompts</p>
            @* Dos contenedores: lista (izquierda) e ilustración (derecha) *@
            <div class="perfil-actividad-layout">
              <section class="perfil-actividad-contenedor perfil-actividad-contenedor-lista">
                @* Scroll interno: el contenedor mantiene la misma altura que la imagen *@
                <div class="perfil-actividad-lista-scroll" tabindex="0" role="region" aria-label="Lista de actividad">
                  @if (Model.Actividad.Count == 0)
                  {
                    <p class="text-muted mb-0">Sin actividad reciente.</p>
                  }
                  else
                  {
                    <ul class="list-unstyled mb-0 perfil-actividad-list">
                      @foreach (var ev in Model.Actividad)
                      {
                        var tipo = ev.Tipo.ToLowerInvariant();
                        var icono = tipo == "guardado" ? "bi-bookmark-fill" : tipo == "like" ? "bi-heart-fill" : "bi-chat-dots-fill";
                        var verbo = tipo == "guardado" ? " guardó " : tipo == "like" ? " dio me gusta a " : " comentó en ";
                        <li class="perfil-actividad-item d-flex gap-3 py-3 border-bottom border-light">
                          <div class="perfil-actividad-icon rounded-circle d-flex align-items-center justify-content-center flex-shrink-0">
                            <i class="bi @icono text-white small"></i>
                          </div>
                          <div class="flex-grow-1 perfil-actividad-texto">
                            <p class="mb-1 small">
                              <span class="fw-semibold">@ev.ActorNombre</span>
                              <span class="text-muted">@@@ev.ActorUserName</span>@verbo<span class="fw-semibold">«@ev.TituloPrompt»</span>
                            </p>
                            @if (tipo == "comentario" && !string.IsNullOrWhiteSpace(ev.ExtractoComentario))
                            {
                              <p class="mb-1 small text-muted fst-italic border-start border-3 ps-2 perfil-actividad-cita">@ev.ExtractoComentario</p>
                            }
                            <p class="mb-0 text-muted extra-small">@ev.Momento</p>
                          </div>
                        </li>
                      }
                    </ul>
                  }
                </div>
              </section>
              <section class="perfil-actividad-contenedor perfil-actividad-contenedor-imagen" aria-label="Ilustración de la comunidad">
                <img src="~/Imagenes/robotIA/RobotSinfondo.png"
                     alt="Robot IA"
                     class="perfil-actividad-robot" />
              </section>
            </div>
          }
          else if (prompts.Count == 0)
          {
            <p class="text-muted mb-0 perfil-vacio">No hay prompts en esta sección.</p>
          }
          else
          {
            @* Tarjetas altura fija 320px; métricas SVG solo en Publicados *@
            <div class="row g-4">
              @foreach (var p in prompts)
              {
                var mostrarMetricas = tab == "publicados";
                <div class="col-12 col-md-6">
                  <div class="card border-0 shadow-sm rounded-4 perfil-prompt-card">
                    <div class="card-body perfil-prompt-card-body">
                      <div class="perfil-prompt-card-main">
                        <h3 class="perfil-prompt-title fw-semibold mb-2">@p.Title</h3>
                        <span class="badge categoria-badge rounded-pill px-3 py-2 perfil-prompt-categoria">@p.Category</span>
                        <div class="perfil-prompt-content rounded-3 p-3 mt-3">
                          <p class="mb-0 perfil-prompt-texto">@p.Prompt</p>
                        </div>
                      </div>
                      @if (mostrarMetricas)
                      {
                        <div class="perfil-prompt-metrics d-flex gap-4">
                          <span class="perfil-metrica" aria-label="Me gusta">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="perfil-metrica-icon bi bi-heart" viewBox="0 0 16 16" aria-hidden="true">
                              <path d="m8 2.748-.717-.737C5.6.281 2.514.878 1.4 3.053c-.523 1.023-.641 2.5.314 4.385.92 1.815 2.834 3.989 6.286 6.357 3.452-2.368 5.365-4.542 6.286-6.357.955-1.886.838-3.362.314-4.385C13.486.878 10.4.28 8.717 2.01zM8 15C-7.333 4.868 3.279-3.04 7.824 1.143q.09.083.176.171a3 3 0 0 1 .176-.17C12.72-3.042 23.333 4.867 8 15"/>
                            </svg>
                            <span>@p.Likes</span>
                          </span>
                          <span class="perfil-metrica" aria-label="Comentarios">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="perfil-metrica-icon bi bi-chat" viewBox="0 0 16 16" aria-hidden="true">
                              <path d="M2.678 11.894a1 1 0 0 1 .287.801 11 11 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8 8 0 0 0 8 14c3.996 0 7-2.807 7-6s-3.004-6-7-6-7 2.808-7 6c0 1.468.617 2.83 1.678 3.894m-.493 3.905a22 22 0 0 1-.713.129c-.2.032-.352-.176-.273-.362a10 10 0 0 0 .244-.637l.003-.01c.248-.72.45-1.548.524-2.319C.743 11.37 0 9.76 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7-3.582 7-8 7a9 9 0 0 1-2.347-.306c-.52.263-1.639.742-3.468 1.105"/>
                            </svg>
                            <span>@p.Comments</span>
                          </span>
                          <span class="perfil-metrica" aria-label="Guardados">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="perfil-metrica-icon bi bi-bookmark" viewBox="0 0 16 16" aria-hidden="true">
                              <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.777.416L8 13.101l-5.223 2.815A.5.5 0 0 1 2 15.5zm2-1a1 1 0 0 0-1 1v12.566l4.723-2.482a.5.5 0 0 1 .554 0L13 14.566V2a1 1 0 0 0-1-1z"/>
                            </svg>
                            <span>@p.Saves</span>
                          </span>
                        </div>
                      }
                    </div>
                  </div>
                </div>
              }
            </div>
          }

        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script src="~/js/perfil.js" asp-append-version="true"></script>
}
