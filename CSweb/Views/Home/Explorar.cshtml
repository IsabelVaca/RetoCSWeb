@model CSweb.Models.ExplorarViewModel

@{
    ViewData["Title"] = "Explorar";
    Layout = "_Layout";
}

<div class="py-5">
    <div class="container">
        <div class="mb-5">

            @* buscador: hace GET porque solo consulta prompts *@
            @using (Html.BeginForm(actionName: "Explorar", "Home", FormMethod.Get))
            {
                <div class="row justify-content-center mb-4">
                    <div class="col-12 col-md-8 col-lg-6">
                        <div class="explorar-search-container d-flex align-items-center px-3 py-1">
                            <i class="bi bi-search text-muted ms-2"></i>

                            <input class="form-control explorar-search-input"
                                type="search"
                                name="query"
                                placeholder="Buscar prompts..."
                                aria-label="Buscar"
                                value="@Model.Query" />

                            @* mantiene el filtro activo cuando buscas *@
                            <input type="hidden"
                                name="filtro"
                                value="@Model.FiltroActivo" />

                            <button class="btn explorar-btn-search ms-2" type="submit">
                                Buscar
                            </button>
                        </div>
                    </div>
                </div>
            }

            @* botones de filtros *@
            <div class="d-flex align-items-center gap-2 flex-wrap mt-5 mb-4">
                @foreach (var filter in Model.Filters)
                {
                    <a href="@Url.Action("Explorar", "Home", new { query = Model.Query, filtro = filter })"
                    class="btn filtro-btn rounded-pill px-4 py-2 shadow-sm @(Model.FiltroActivo == filter ? "active" : "")">

                        @if (filter == "Tendencias")
                        {
                            <i class="bi bi-arrow-up-right"></i>
                        }

                        @if (filter == "Recientes")
                        {
                            <i class="bi bi-clock-history"></i>
                        }

                        @if (filter == "Más Gustados")
                        {
                            <i class="bi bi-heart"></i>
                        }

                        @if (filter == "Más Guardados")
                        {
                            <i class="bi bi-bookmark"></i>
                        }

                        @filter
                    </a>
                }
            </div>

            @* contenedor de prompts *@
            <div class="row g-4" id="promptsGrid">

                @if (Model?.Prompts != null && Model.Prompts.Count > 0)
                {
                    @foreach (var prompt in Model.Prompts)
                    {
                        <div class="col-12 col-lg-6 prompt-item">

                            <div class="card prompt-card h-100 border-0 shadow-lg rounded-4">
                                <div class="card-body p-4">

                                    @* encabezado de tarjeta: usuario + badge tendencia *@
                                    <div class="d-flex align-items-center justify-content-between mb-4">

                                        <a asp-controller="Home"
                                        asp-action="Perfil"
                                        class="d-flex align-items-center gap-3 text-start text-decoration-none text-dark">

                                            <div class="avatar-circle text-white fw-semibold"
                                                style="background-color:@prompt.CircleColor">
                                                @prompt.InitialsProfile
                                            </div>

                                            <div>
                                                <p class="mb-0 fw-semibold small">@prompt.AuthorName</p>
                                                <p class="mb-0 text-muted extra-small">@@@prompt.Username</p>
                                            </div>

                                        </a>

                                        @if (prompt.Trending==1)
                                        {
                                            <span class="badge tendencia-badge rounded-pill px-3 py-2">
                                                ↗ Tendencia
                                            </span>
                                        }

                                    </div>

                                    @* título y categoría *@
                                    <div class="mb-3">
                                        <h3 class="h5 fw-semibold mb-2">@prompt.Title</h3>

                                        <span class="badge categoria-badge rounded-pill px-3 py-2">
                                            @prompt.Category
                                        </span>
                                    </div>

                                    @* contenido del prompt *@
                                    <div class="prompt-content rounded-4 p-3 mb-4">
                                        <p class="mb-0 text-muted small lh-base">
                                            @prompt.Prompt
                                        </p>
                                    </div>

                                    @* footer de acciones *@
                                    <div class="d-flex align-items-center justify-content-between pt-3 border-top">

                                        <div class="d-flex align-items-center gap-4 text-muted">

                                            @* LIKE: formulario normal, sin JavaScript *@
                                            <form method="post"
                                                asp-controller="Home"
                                                asp-action="ToggleLike"
                                                class="m-0">

                                                <input type="hidden" name="promptId" value="@prompt.Id" />
                                                <input type="hidden" name="query" value="@Model.Query" />
                                                <input type="hidden" name="filtro" value="@Model.FiltroActivo" />

                                                <button type="submit"
                                                        class="stat-icon-btn like-btn @(prompt.LikedByMe==1 ? "liked" : "")">
                                                    <i class="bi @(prompt.LikedByMe ==1 ? "bi-heart-fill" : "bi-heart")"></i>
                                                    <span class="like-count">@prompt.Likes</span>
                                                </button>
                                            </form>

                                            @* COMENTARIOS: indicador del total *@
                                            <button type="button"
                                                    class="stat-icon-btn">
                                                <i class="bi bi-chat"></i>
                                                <span class="comment-count">@prompt.Comments</span>
                                            </button>

                                            @* GUARDAR: formulario normal, sin JavaScript *@
                                            <form method="post"
                                                asp-controller="Home"
                                                asp-action="ToggleGuardar"
                                                class="m-0">

                                                <input type="hidden" name="promptId" value="@prompt.Id" />
                                                <input type="hidden" name="query" value="@Model.Query" />
                                                <input type="hidden" name="filtro" value="@Model.FiltroActivo" />

                                                <button type="submit"
                                                        class="stat-icon-btn save-btn @(prompt.SavedByMe ==1 ? "saved" : "")">
                                                    <i class="bi @(prompt.SavedByMe ==1 ? "bi-bookmark-fill" : "bi-bookmark")"></i>
                                                    <span class="save-count">@prompt.Saves</span>
                                                </button>
                                            </form>

                                        </div>

                                        <div class="d-flex align-items-center gap-3">
                                            <span class="text-muted extra-small">@prompt.CreatedAt</span>

                                            <button type="button" class="stat-icon-btn share-icon-btn">
                                                <i class="bi bi-share"></i>
                                            </button>
                                        </div>

                                    </div>

                                    @* comentario: formulario normal, sin JavaScript *@
                                    <div class="comment-section mt-4 pt-4 border-top show"
                                        id="comments-@prompt.Id">

                                        <form method="post"
                                            asp-controller="Home"
                                            asp-action="PublicarComentario"
                                            class="d-flex gap-2">

                                            <input type="hidden" name="promptId" value="@prompt.Id" />
                                            <input type="hidden" name="query" value="@Model.Query" />
                                            <input type="hidden" name="filtro" value="@Model.FiltroActivo" />

                                            <input type="text"
                                                name="comentario"
                                                class="form-control rounded-4 comment-input"
                                                placeholder="Añadir un comentario..." />

                                            <button type="submit"
                                                    class="btn publicar-btn rounded-4 px-3">
                                                Publicar
                                            </button>

                                        </form>

                                        <p class="text-muted extra-small mt-2 mb-0">
                                            Sé respetuoso y constructivo en tus comentarios
                                        </p>

                                    </div>

                                </div>
                            </div>

                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="display-3 mb-3">✨</div>
                        <h3 class="h4 mb-2">No se encontraron prompts</h3>
                        <p class="text-muted">Intenta ajustar tu búsqueda o filtros</p>
                    </div>
                }

            </div>

        </div>
    </div>
</div>